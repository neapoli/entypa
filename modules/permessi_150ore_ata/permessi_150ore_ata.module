<?php

/**
 * Implements hook_theme_registry_alter().
 *
 * Registers the entity_print template suggestion for the "adesione_a_commissioni"
 * webform so entity_print can find the file in this submodule's templates directory.
 */
function permessi_150ore_ata_theme_registry_alter(&$theme_registry) {
  if (!isset($theme_registry['entity_print'])) {
    return;
  }
  $module_path = \Drupal::service('extension.list.module')->getPath('permessi_150ore_ata');
  $theme_registry['entity_print__webform_submission__permessi_150ore_ata'] = [
    'base hook' => 'entity_print',
    'path' => $module_path . '/templates/entity_print',
    'template' => 'entity-print--webform-submission--permessi-150ore-ata',
    'type' => 'module',
    'theme path' => $module_path,
    'variables' => $theme_registry['entity_print']['variables'] ?? [],
    'preprocess functions' => $theme_registry['entity_print']['preprocess functions'] ?? [],
  ];
}
