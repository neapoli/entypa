{#
/**
 * @file
 * Default theme implementation for webform submission data.
 *
 * Available variables:
 * - webform_submission: The webform submission.
 * - webform: The webform.
 *
 * @see template_preprocess_webform_submission_data()
 *
 * @ingroup themeable
 */
#}
<html lang="it">
  <head>
    <meta charset="utf-8">
    <title>{{ title }}</title>
    {{ entity_print_css }}
  </head>
  <body>

    {# The footer is repeated on all pages and must be printed first. #}
    <div id="footer">
      <p class="page">Pagina </p>
    </div>

    <div id="header">
    </div>

    <div id="content">
      <div class="content_header">
        <p style="float: right;">Al Dirigente scolastico<br />
           {{ data.istituto }} <br />
           {{ data.mail_istituto }}
        </p>
        <p style="clear: right;">&nbsp;</p>
      </div>
      <div class="oggetto">
        <p>Oggetto: <strong>Adesione a commissioni - {{ data.cognome }} {{ data.nome }}</strong></p>
      </div>
      <div class="corpo">
        <p>
          Il/La sottoscritto/a {{ data.cognome }} {{ data.nome }}
          in servizio presso {{ data.sede_di_servizio }}
          in qualità di {{ data.in_qualita_di_ }} a tempo {{ data.a_tempo }}<br>
        </p>
        <p>{{ elements.processed_text }}</p>
        <div style="margin-top: 20px;">
          <p>Commissione:
            {{ webform_token('[webform_submission:values:commissione]', webform_submission, [], options) }}
          </p>
        </div>
        <div style="margin-top: 20px;">
          {% if data.note %}
            <p>Note<br /> {{ data.note }}</p>
          {% endif %}
        </div>
        <div class="data_invio">
          <p>Data {{ data.data_compilazione|date('d.m.Y') }}</p>
        </div>
        <div class="firma_docente">
          <div class="firma">
            <strong>Firma</strong><br>
            {{ data.cognome }} {{ data.nome }}<br />
            {{ data.codice_fiscale }}<br />
            {{ data.mail_user }}
          </div>
        </div>
      </div>
      {#  <p style="page-break-before: always;">the second page</p>#}
      <div class="autorizzazione">
        <p>
        </p>
        <div class="firma_ata"></div>
        <div class="firma_ds"></div>
      </div>
    </div>
    {#
    {{ kint(data) }}
     {{ kint(elements) }}
    {{ kint(content) }}
    #}
  </body>
</html>
