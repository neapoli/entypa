{#
/**
 * @file
 * Default theme implementation for webform submission data.
 *
 * Available variables:
 * - webform_submission: The webform submission.
 * - webform: The webform.
 *
 * @see template_preprocess_webform_submission_data()
 *
 * @ingroup themeable
 */
#}
<html lang="it">
  <head>
    <meta charset="utf-8">
    <title>{{ title }}</title>
    {{ entity_print_css }}
  </head>
  <body>

    {# The footer is repeated on all pages and must be printed first. #}
    <div id="footer">
    </div>

    <div id="header">
    </div>

    <div id="content">
      <div class="content_header">
        <p>Al Dirigente scolastico<br />
         {{ data.istituto }} <br />
         {{ data.mail_istituto }}
        </p>
      </div>
      <div>
        <p>Oggetto: <strong>Richiesta Assenza Per Malattia - {{ data.cognome }} {{ data.nome }}</strong></p>
      </div>
      <div class="corpo">
        <p>
          Il/La sottoscritto/a {{ data.cognome }} {{ data.nome }}
          in servizio presso {{ data.sede_di_servizio }}
          in qualità di {{ data.in_qualita_di_ }} a tempo {{ data.a_tempo }}
          <em>ai sensi del C.C.N.L. comparto scuola del 29.11.2007,</em><br>
        </p>
        <p class="center">COMUNICA</p>
        <p>
            di doversi assentare per il seguente motivo: <strong>{{ data.tipologia_richiesta }}</strong><br>
            dal: <strong>{{ data.data_inizio|date('d.m.Y') }}</strong> al: <strong>{{ data.data_fine|date('d.m.Y') }}</strong>
            per un numero totale di giorni pari a: <strong>{{ data.numero_giorni }}</strong>
        </p>
        {% if data.certificato_medico %}
          <p>
            Numero del certificato rilasciato dal medico curante: <strong>{{ data.certificato_medico}}</strong>
          </p>
        {% else %}
          <p>
            di non essere in possesso della documentazione necessaria al momento della presente richiesta e,
            che la stessa, verrà consegnata in segreteria non appena sarà possibile.
          </p>
        {% endif %}
        {% if data.indirizzo %}
          <p><strong>Reperibilità dichiarata</strong><br />
            indirizzo: {{ data.indirizzo}} <br />
			      numero telefonico : {{ data.telefono}}
          </p>
        {% endif %}
        {% if data.note %}
          <p><strong>Note</strong><br />
            {{ data.note}}
          </p>
        {% endif %}
        <div class="data_invio">
          <p>Data {{ data.data_compilazione|date('d.m.Y') }}</p>
        </div>
        <div class="firma_docente">
          <div class="firma">
            <strong>Firma</strong><br>
            {{ data.cognome }} {{ data.nome }}<br />
			      codice fiscale {{ data.codice_fiscale }}<br />
			      {{ data.mail_user }}
          </div>
        </div>
      </div>
      {#  <p style="page-break-before: always;">the second page</p>#}
      <div class="autorizzazione">
        <p>
        </p>
        <div class="firma_ata"></div>
        <div class="firma_ds"></div>
      </div>
    </div>
    {#
    {{ kint(data) }}
     {{ kint(elements) }}
    {{ kint(content) }}
#}
  </body>
</html>
